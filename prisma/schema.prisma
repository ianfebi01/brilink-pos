// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  role      String   @default("admin") // "superadmin" or "admin"
  createdAt DateTime @default(now())

  transactions      Transaction[]
  dailyInvestments  DailyInvestment[]
}

model TransactionCategory {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  isActive    Boolean  @default(true)

  feeRules     FeeRule[]
  transactions Transaction[]
}

model FeeRule {
  id          String   @id @default(cuid())
  categoryId  String
  name        String

  minAmount   Decimal?
  maxAmount   Decimal?

  formulaJson Json

  isActive    Boolean  @default(true)

  category    TransactionCategory @relation(fields: [categoryId], references: [id])

  transactions Transaction[]

  createdAt DateTime @default(now())
}

model Transaction {
  id                  String   @id @default(cuid())

  categoryId          String
  feeRuleId           String?

  transactionAmount   Decimal
  customerFee         Decimal
  briFee              Decimal
  agentProfit         Decimal
  totalPaid           Decimal

  customerName        String?
  note                String?

  createdById         String

  createdAt           DateTime @default(now())

  category            TransactionCategory @relation(fields: [categoryId], references: [id])
  feeRule             FeeRule?            @relation(fields: [feeRuleId], references: [id])
  createdBy           User                @relation(fields: [createdById], references: [id])
}

model DailyInvestment {
  id            String   @id @default(cuid())
  amount        Decimal
  note          String?

  investmentDate DateTime @db.Date

  createdById   String

  createdAt     DateTime @default(now())

  createdBy User @relation(fields: [createdById], references: [id])
}
